+AI_LIMIT_RE = re.compile(r"out of extra usage|usage limit reached", re.I)
+AI_LIMIT_RESET_RE = re.compile(r"resets?\s+(\d{1,2}):(\d{2})\s*(am|pm)", re.I)
+AI_LIMIT_BACKOFF = 1800        # fallback hold when the reset time can't be parsed
+AI_HEALTH = {"limited_until": 0.0, "since": None}   # guarded by LOCK
+USAGE_LOCK = threading.Lock()
+TASK_RUNS_LOCK = threading.Lock()
